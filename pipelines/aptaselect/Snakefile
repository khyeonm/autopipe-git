configfile: "config.yaml"

import json

rule all:
    input:
        "/output/aptaselect_top_sequences.tsv",
        "/output/aptaselect_stats.json"

rule prepare_config:
    """Convert YAML config parameters to JSON for the Python script."""
    output:
        temp("/output/run_config.json")
    run:
        run_config = {
            "min_overlap": config["min_overlap"],
            "pct_diff": config["pct_diff"],
            "is_short": config["is_short"],
            "sel_read1": config["sel_read1"],
            "sel_read2": config["sel_read2"],
            "s1_read1": config["s1_read1"],
            "s1_read2": config["s1_read2"],
            "s1_length": config["s1_length"],
            "s2_read1": config["s2_read1"],
            "s2_read2": config["s2_read2"],
            "s2_length": config["s2_length"],
            "max_mismatches": config["max_mismatches"],
            "top_n": config["top_n"],
        }
        with open(output[0], 'w') as f:
            json.dump(run_config, f, indent=2)

rule aptaselect:
    """Run the AptaSelect pipeline: Join, Filter, Aggregate & Rank."""
    input:
        read1="/input/" + config["read1"],
        read2="/input/" + config["read2"],
        run_config="/output/run_config.json"
    output:
        tsv="/output/aptaselect_top_sequences.tsv",
        stats="/output/aptaselect_stats.json"
    log:
        "/output/logs/aptaselect.log"
    params:
        chunk_size=config.get("chunk_size", 10000)
    shell:
        """
        python /pipeline/scripts/aptaselect.py \
            --read1 {input.read1} \
            --read2 {input.read2} \
            --output {output.tsv} \
            --stats {output.stats} \
            --config {input.run_config} \
            --chunk-size {params.chunk_size} \
            2>&1 | tee {log}
        """