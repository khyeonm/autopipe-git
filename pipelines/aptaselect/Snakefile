configfile: "config.yaml"

OUTPUT = "/output"

rule all:
    input:
        f"{OUTPUT}/aptaselect_top_candidates.tsv",
        f"{OUTPUT}/aptaselect_stats.json"


rule aptaselect:
    """Run the AptaSelect pipeline: join, filter, aggregate, and rank aptamer candidates."""
    input:
        r1=config["read1"],
        r2=config["read2"]
    output:
        candidates=f"{OUTPUT}/aptaselect_top_candidates.tsv",
        stats=f"{OUTPUT}/aptaselect_stats.json"
    log:
        f"{OUTPUT}/logs/aptaselect.log"
    threads: 1
    shell:
        """
        mkdir -p {OUTPUT}/logs
        python /pipeline/scripts/aptaselect.py \
            --r1 {input.r1} \
            --r2 {input.r2} \
            --output {output.candidates} \
            --stats {output.stats} \
            --config config.yaml \
            2>&1 | tee {log}
        """