configfile: "config.yaml"

rule all:
    input:
        "/output/deg_results.tsv",
        "/output/top_markers_by_group.tsv",
        "/output/analysis_summary.json",
        "/output/qc_overview.png",
        "/output/deg_dotplot.png"

rule single_cell_deg:
    """Run single-cell differential expression and optional Squidpy neighborhood analysis."""
    input:
        h5ad=config["input_h5ad"]
    output:
        deg="/output/deg_results.tsv",
        top="/output/top_markers_by_group.tsv",
        summary="/output/analysis_summary.json",
        qc="/output/qc_overview.png",
        dotplot="/output/deg_dotplot.png",
        nhood="/output/squidpy_neighborhood_enrichment.tsv",
        spatial_autocorr="/output/squidpy_spatial_autocorr.tsv"
    threads: config.get("threads", 4)
    log:
        "/output/single_cell_deg.log"
    params:
        groupby=config["groupby"],
        reference=config.get("reference", "rest"),
        method=config.get("method", "wilcoxon"),
        layer=config.get("layer", ""),
        use_raw=config.get("use_raw", False),
        min_cells=config.get("min_cells", 3),
        normalize_total=config.get("normalize_total", True),
        target_sum=config.get("target_sum", 10000),
        log1p=config.get("log1p", True),
        n_top_genes=config.get("n_top_genes", 25),
        spatial_library_key=config.get("spatial_library_key", ""),
        spatial_coord_type=config.get("spatial_coord_type", "generic"),
        spatial_radius=config.get("spatial_radius", ""),
        spatial_n_neighs=config.get("spatial_n_neighs", 6),
        spatial_autocorr_genes=config.get("spatial_autocorr_genes", 100)
    shell:
        """
        python /pipeline/scripts/run_deg.py \
            --input-h5ad {input.h5ad} \
            --output-dir /output \
            --groupby {params.groupby} \
            --reference {params.reference} \
            --method {params.method} \
            --layer "{params.layer}" \
            --use-raw {params.use_raw} \
            --min-cells {params.min_cells} \
            --normalize-total {params.normalize_total} \
            --target-sum {params.target_sum} \
            --log1p {params.log1p} \
            --n-top-genes {params.n_top_genes} \
            --spatial-library-key "{params.spatial_library_key}" \
            --spatial-coord-type {params.spatial_coord_type} \
            --spatial-radius "{params.spatial_radius}" \
            --spatial-n-neighs {params.spatial_n_neighs} \
            --spatial-autocorr-genes {params.spatial_autocorr_genes} \
            --threads {threads} \
            2>&1 | tee {log}
        """