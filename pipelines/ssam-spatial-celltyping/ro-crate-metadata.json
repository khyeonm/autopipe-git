        "smFISH",
        "MERFISH",
        "seqFISH",
        "single-molecule",
        "spatial-omics"
      ],
      "license": {
        "@id": "https://spdx.org/licenses/AGPL-3.0"
      },
      "name": "ssam-spatial-celltyping",
