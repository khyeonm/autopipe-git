    {
      "@id": "./",
      "@type": ["Dataset", "SoftwareSourceCode", "ComputationalWorkflow"],
      "name": "ssam-spatial-celltyping",
      "description": "Cell segmentation-free spatial cell-type inference using SSAM (Spot-based Spatial cell-type Analysis by Multidimensional mRNA density estimation). Applies KDE to single-molecule mRNA coordinates and maps pixel-level gene expression vectors to cell-type signatures, producing a spatial cell-type map and abundance statistics.",
      "version": "1.0.0",
      "license": {"@id": "https://spdx.org/licenses/AGPL-3.0"},
      "programmingLanguage": {"@id": "#snakemake"},
      "creator": [{"@id": "#author"}],
      "dateCreated": "2026-03-10",
      "sdPublisher": {"@id": "https://hub.autopipe.org"},
      "isBasedOn": {"@id": "https://github.com/pnucolab/ssam"},
      "softwareRequirements": [
        {"@id": "#ssam"},
        {"@id": "#scanpy"},
        {"@id": "#anndata"}
      ],
      "input": [
        {"@id": "#input-coordinates"},
        {"@id": "#input-signatures"}
      ],
      "output": [
        {"@id": "#output-h5ad"},
        {"@id": "#output-celltype-map"},
        {"@id": "#output-kde-map"},
        {"@id": "#output-abundance"}
      ],
      "keywords": [
        "spatial-transcriptomics", "SSAM", "cell-type-mapping",
        "KDE", "segmentation-free", "smFISH", "MERFISH", "seqFISH",
        "single-molecule", "spatial-omics"
      ]
    },
    {
      "@id": "#author",
      "@type": "Person",
      "name": "khyeonmin"
    },
    {
      "@id": "#snakemake",
      "@type": "ComputerLanguage",
      "name": "Snakemake",
      "url": "https://snakemake.readthedocs.io"
    },
    {
      "@id": "#ssam",
      "@type": "SoftwareApplication",
      "name": "SSAM",
      "url": "https://github.com/pnucolab/ssam"
    },
    {
      "@id": "#scanpy",
      "@type": "SoftwareApplication",
      "name": "scanpy"
    },
    {
      "@id": "#anndata",
      "@type": "SoftwareApplication",
      "name": "anndata"
    },
    {
      "@id": "#input-coordinates",
      "@type": "FormalParameter",
      "name": "coordinates.csv",
      "encodingFormat": "text/csv",
      "description": "mRNA molecule coordinates: columns gene, x, y"
    },
    {
      "@id": "#input-signatures",
      "@type": "FormalParameter",
      "name": "signatures.csv",
      "encodingFormat": "text/csv",
      "description": "Cell-type gene expression signatures: rows=cell types, columns=genes"
    },
    {
      "@id": "#output-h5ad",
      "@type": "FormalParameter",
      "name": "ssam_result.h5ad",
      "encodingFormat": "application/x-hdf5"
    },
    {
      "@id": "#output-celltype-map",
      "@type": "FormalParameter",
      "name": "celltype_map.png",
      "encodingFormat": "image/png"
    },
    {
      "@id": "#output-kde-map",
      "@type": "FormalParameter",
      "name": "kde_map.png",
      "encodingFormat": "image/png"
    },
    {
      "@id": "#output-abundance",
      "@type": "FormalParameter",
      "name": "celltype_abundance.csv",
      "encodingFormat": "text/csv"
    }
  ]
