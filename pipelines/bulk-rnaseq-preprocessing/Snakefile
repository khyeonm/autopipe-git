configfile: "config.yaml"

# nf-core/rnaseq preprocessing pipeline (STAR + Salmon)
# This Snakefile wraps the nf-core/rnaseq Nextflow pipeline

rule all:
    input:
        "/output/nfcore/multiqc/star_salmon/multiqc_report.html"

rule run_nfcore_rnaseq:
    """
    Run nf-core/rnaseq pipeline with STAR-Salmon workflow.
    Uses Docker-in-Docker via HOST_* environment variables.
    """
    output:
        "/output/nfcore/multiqc/star_salmon/multiqc_report.html"
    params:
        nfcore_version=config["nfcore_rnaseq_version"],
        genome=config["genome"],
        fasta=config.get("fasta", ""),
        gtf=config.get("gtf", ""),
        star_index=config.get("star_index", ""),
        salmon_index=config.get("salmon_index", ""),
        extra=config.get("extra_params", ""),
        igenomes_base=config.get("igenomes_base", "null"),
        trimmer=config.get("trimmer", "trimgalore"),
        min_trimmed_reads=config.get("min_trimmed_reads", 10000),
        max_cpus=config.get("max_cpus", 16),
        max_memory=config.get("max_memory", "64.GB"),
        max_time=config.get("max_time", "240.h")
    threads: config.get("threads", 16)
    log:
        "/output/logs/nfcore_rnaseq.log"
    shell:
        """
        mkdir -p /output/logs

        export NXF_HOME=$HOST_OUTPUT_DIR/.nextflow

        # Build the nextflow command with HOST paths for Docker-in-Docker
        CMD="nextflow run nf-core/rnaseq -r {params.nfcore_version} -profile docker"
        CMD="$CMD --input $HOST_INPUT_DIR/samplesheet.csv"
        CMD="$CMD --outdir $HOST_OUTPUT_DIR/nfcore"
        CMD="$CMD -w $HOST_OUTPUT_DIR/.nextflow/work"
        CMD="$CMD --aligner star_salmon"

        # Genome setting
        if [ "{params.genome}" != "null" ] && [ -n "{params.genome}" ]; then
            CMD="$CMD --genome {params.genome}"
        fi

        # Set iGenomes base
        if [ "{params.igenomes_base}" = "null" ]; then
            CMD="$CMD --igenomes_base null"
        else
            CMD="$CMD --igenomes_base {params.igenomes_base}"
        fi

        # Add reference files using HOST_INPUT_DIR paths (required for Docker-in-Docker)
        FASTA_BASENAME=$(basename "{params.fasta}")
        GTF_BASENAME=$(basename "{params.gtf}")

        if [ -n "{params.fasta}" ]; then
            CMD="$CMD --fasta $HOST_INPUT_DIR/$FASTA_BASENAME"
        fi
        if [ -n "{params.gtf}" ]; then
            CMD="$CMD --gtf $HOST_INPUT_DIR/$GTF_BASENAME"
        fi
        if [ -n "{params.star_index}" ]; then
            CMD="$CMD --star_index $HOST_INPUT_DIR/$(basename '{params.star_index}')"
        fi
        if [ -n "{params.salmon_index}" ]; then
            CMD="$CMD --salmon_index $HOST_INPUT_DIR/$(basename '{params.salmon_index}')"
        fi

        # Trimming and resource settings
        CMD="$CMD --trimmer {params.trimmer}"
        CMD="$CMD --min_trimmed_reads {params.min_trimmed_reads}"
        CMD="$CMD --max_cpus {params.max_cpus}"
        CMD="$CMD --max_memory {params.max_memory}"
        CMD="$CMD --max_time {params.max_time}"

        # Extra parameters
        if [ -n "{params.extra}" ]; then
            CMD="$CMD {params.extra}"
        fi

        echo "Running: $CMD" > {log}
        eval $CMD >> {log} 2>&1
        """