configfile: "config.yaml"

rule all:
    input:
        expand("/output/{f}", f=[
            "joined_all.tsv",
            "selection_all.tsv",
            "sort1_all.tsv",
            "sort2_all.tsv",
            "summary.txt"
        ])

rule aptaselect:
    input:
        read1 = config["read1"],
        read2 = config["read2"]
    output:
        joined    = "/output/joined_all.tsv",
        selection = "/output/selection_all.tsv",
        sort1     = "/output/sort1_all.tsv",
        sort2     = "/output/sort2_all.tsv",
        summary   = "/output/summary.txt"
    threads: config.get("threads", 4)
    log:
        "/output/aptaselect.log"
    shell:
        """
        python /pipeline/scripts/aptaselect.py \
            --read1           {input.read1} \
            --read2           {input.read2} \
            --outdir          /output \
            --min_overlap     {config[min_overlap]} \
            --pct_diff        {config[pct_diff]} \
            --is_short        {config[is_short]} \
            --sel_read1       {config[sel_read1]} \
            --sel_read2       {config[sel_read2]} \
            --s1_read1        {config[s1_read1]} \
            --s1_read2        {config[s1_read2]} \
            --s1_length       {config[s1_length]} \
            --s2_read1        {config[s2_read1]} \
            --s2_read2        {config[s2_read2]} \
            --s2_length       {config[s2_length]} \
            --max_mismatches  {config[max_mismatches]} \
            --top_n           {config[top_n]} \
            --chunk_size      {config[chunk_size]} \
            --threads         {threads} \
            2>&1 | tee {log}
        """