configfile: "config.yaml"

import os
import glob

# ── helpers ──────────────────────────────────────────────────────────────────

def get_chunks(wildcards):
    """Return list of chunk IDs after the split step has run."""
    manifest = checkpoints.split_chunks.get(**wildcards).output.manifest
    with open(manifest) as f:
        return [line.strip() for line in f if line.strip()]

def chunk_stage2(wildcards):
    chunks = get_chunks(wildcards)
    return expand("/output/stage2/{chunk}.tsv", chunk=chunks)

def chunk_stage3(wildcards):
    chunks = get_chunks(wildcards)
    return expand("/output/stage3/{chunk}.tsv", chunk=chunks)

def chunk_stage4(wildcards):
    chunks = get_chunks(wildcards)
    return expand("/output/stage4/{chunk}.tsv", chunk=chunks)

# ── target ───────────────────────────────────────────────────────────────────

rule all:
    input:
        "/output/aptaselect_results.tsv"

# ── Stage 1: Join ─────────────────────────────────────────────────────────────

rule join_reads:
    input:
        r1 = config["r1"],
        r2 = config["r2"]
    output:
        joined = "/output/joined.txt"
    log:
        "/output/logs/join_reads.log"
    threads: 1
    shell:
        """
        python /pipeline/scripts/join_reads.py \
            --r1 {input.r1} \
            --r2 {input.r2} \
            --output {output.joined} \
            --min-overlap {config[min_overlap]} \
            --pct-diff {config[pct_diff]} \
            --is-short {config[is_short]} \
            2> {log}
        """

# ── Split joined reads into parallel chunks ───────────────────────────────────

checkpoint split_chunks:
    input:
        joined = "/output/joined.txt"
    output:
        manifest = "/output/chunks/chunks.txt"
    params:
        outdir = "/output/chunks"
    log:
        "/output/logs/split_chunks.log"
    threads: 1
    shell:
        """
        python /pipeline/scripts/split_chunks.py \
            --input {input.joined} \
            --output-dir {params.outdir} \
            --chunk-size {config[chunk_size]} \
            2> {log}
        """

# ── Stage 2: Selection Filtering ─────────────────────────────────────────────

rule stage2_selection:
    input:
        "/output/chunks/{chunk}.txt"
    output:
        "/output/stage2/{chunk}.tsv"
    log:
        "/output/logs/stage2_{chunk}.log"
    threads: 1
    shell:
        """
        python /pipeline/scripts/filter_patterns.py \
            --input {input} \
            --output {output} \
            --pat1 '{config[sel_read1]}' \
            --pat2 '{config[sel_read2]}' \
            --max-mismatches {config[max_mismatches]} \
            2> {log}
        """

# ── Stage 3: 1st Sort Filtering ───────────────────────────────────────────────

rule stage3_sort1:
    input:
        "/output/stage2/{chunk}.tsv"
    output:
        "/output/stage3/{chunk}.tsv"
    log:
        "/output/logs/stage3_{chunk}.log"
    threads: 1
    shell:
        """
        python /pipeline/scripts/filter_patterns.py \
            --input {input} \
            --output {output} \
            --pat1 '{config[s1_read1]}' \
            --pat2 '{config[s1_read2]}' \
            --max-mismatches {config[max_mismatches]} \
            --between-length {config[s1_length]} \
            --input-has-counts \
            2> {log}
        """

# ── Stage 4: 2nd Sort Filtering ───────────────────────────────────────────────

rule stage4_sort2:
    input:
        "/output/stage3/{chunk}.tsv"
    output:
        "/output/stage4/{chunk}.tsv"
    log:
        "/output/logs/stage4_{chunk}.log"
    threads: 1
    shell:
        """
        python /pipeline/scripts/filter_patterns.py \
            --input {input} \
            --output {output} \
            --pat1 '{config[s2_read1]}' \
            --pat2 '{config[s2_read2]}' \
            --max-mismatches {config[max_mismatches]} \
            --between-length {config[s2_length]} \
            --input-has-counts \
            2> {log}
        """

# ── Stage 5: Aggregation & Ranking ────────────────────────────────────────────

rule aggregate_rank:
    input:
        chunk_stage4
    output:
        "/output/aptaselect_results.tsv"
    params:
        stage4_dir = "/output/stage4"
    log:
        "/output/logs/aggregate_rank.log"
    threads: 1
    shell:
        """
        python /pipeline/scripts/aggregate_rank.py \
            --input-dir {params.stage4_dir} \
            --output {output} \
            --top-n {config[top_n]} \
            2> {log}
        """